# ============================================================
# PLANTILLA DE VARIABLES DE ENTORNO - backend/ms-reservas
# Copia como ".env" en esta carpeta y completa con valores reales.
# NUNCA subas ".env" a git.
#
# NOTA: ms-reservas usa PostgreSQL (Neon) via las variables
# SPRING_DATASOURCE_* del .env raiz. Las variables DB_* de abajo
# parecen un remanente de una configuracion MySQL anterior;
# revisar si siguen siendo necesarias antes de completarlas.
# ============================================================

APP_PORT=8003
DB_HOST=rednorte-mysql-dev
DB_PORT=3306
DB_NAME=bd_rednorte
DB_USERNAME=root
DB_PASSWORD=<password>
