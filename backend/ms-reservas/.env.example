# ============================================================
# PLANTILLA DE VARIABLES DE ENTORNO - backend/ms-reservas
# Copia como ".env" en esta carpeta y completa con valores reales.
# NUNCA subas ".env" a git.
#
# NOTA: en uso normal, ms-reservas usa PostgreSQL (Neon) via las
# variables SPRING_DATASOURCE_* del .env raiz. Las variables DB_*
# de abajo solo aplican si levantas este docker-compose.yml de
# forma standalone (fuera del compose raiz) contra un Postgres propio.
# ============================================================

APP_PORT=8003
DB_HOST=rednorte-postgres-dev
DB_PORT=5432
DB_NAME=bd_rednorte
DB_USERNAME=postgres
DB_PASSWORD=<password>
