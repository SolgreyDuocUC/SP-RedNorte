# ============================================================
# PLANTILLA DE VARIABLES DE ENTORNO - db/
# Copia como ".env" en esta carpeta y completa con valores reales.
# NUNCA subas ".env" a git.
# ============================================================

POSTGRES_USER=user_rednorte
POSTGRES_PASSWORD=<user_password>
POSTGRES_DB=bd_rednorte
DB_PORT=3307

# Conexion local (docker-compose de esta carpeta)
JDBC_DATABASE_URL_LOCAL=jdbc:postgresql://localhost:3307/bd_rednorte?user=user_rednorte&password=<user_password>

# Conexion a Neon (produccion) - usar las mismas credenciales que SPRING_DATASOURCE_* del .env raiz
JDBC_DATABASE_URL_PROD=jdbc:postgresql://<host_neon>.neon.tech/<database>?sslmode=require&channelBinding=require

