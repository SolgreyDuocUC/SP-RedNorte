# ============================================================
# PLANTILLA DE VARIABLES DE ENTORNO - SP-RedNorte (raiz)
#
# 1. Copia este archivo como ".env" en la raiz del proyecto:
#      cp .env.example .env
# 2. Completa los valores reales en tu ".env" local.
# 3. NUNCA subas ".env" a git (ya esta en .gitignore).
#    Los valores reales (produccion) deben vivir SOLO en:
#      - tu ".env" local (no versionado)
#      - GitHub Actions Secrets (Settings > Secrets and variables > Actions)
# ============================================================

# --- Base de datos PostgreSQL (Neon / produccion) ---
SPRING_DATASOURCE_URL=jdbc:postgresql://<host-neon>/<db>?sslmode=require&channelBinding=require
SPRING_DATASOURCE_USERNAME=<usuario_neon>
SPRING_DATASOURCE_PASSWORD=<password_neon>
SPRING_DATASOURCE_DRIVER_CLASS_NAME=org.postgresql.Driver

# --- Frontend ---
FRONTEND_PORT=3000

# --- PostgreSQL local (docker-compose, solo desarrollo) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=<password_local_dev>
POSTGRES_DB=bd_rednorte
DB_PORT=5432

# --- SMTP Gmail (ms-notificaciones) ---
# SPRING_MAIL_USERNAME: tu correo de Gmail (ej: tuusuario@gmail.com)
# SPRING_MAIL_PASSWORD: contraseña de aplicación de Gmail (no la contraseña normal)
#   Generala en: https://myaccount.google.com/apppasswords (requiere verificación en 2 pasos)
SPRING_MAIL_HOST=smtp.gmail.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=rednortesaludchile@gmail.com
SPRING_MAIL_PASSWORD=redNorte123

# --- Secreto compartido entre ms-reservas y ms-notificaciones ---
# Header "X-Notification-Secret" que valida NotificationController
NOTIFICATION_SERVICE_SECRET=<secreto_inter_servicios>

# --- CORS (opcional, por defecto "*" en ms-notificaciones) ---
APP_CORS_ALLOWED_ORIGINS=*
